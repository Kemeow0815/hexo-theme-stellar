// 关于页面样式 - 适配 Stellar 主题明暗模式

// 主容器
#about-page
  margin-top: 1rem
  margin-left: auto
  margin-right: auto
  max-width: 1200px
  width: calc(100% - 2rem)
  box-sizing: border-box
  overflow: hidden

// 作者主区域
.author-main
  display: flex
  align-items: center
  justify-content: center
  margin-bottom: 16px
  user-select: none
  flex-wrap: wrap
  gap: 20px

.mainports
  margin: 0 20px

.author-box
  position: relative
  width: 180px
  height: 180px
  background: var(--card)
  border-radius: 50%
  overflow: hidden
  display: flex
  align-items: center
  justify-content: center
  box-shadow: var(--shadow-card)

.author-img
  border-radius: 50%
  width: 180px
  height: 180px
  position: relative
  background: var(--block)
  user-select: none
  transition: transform 0.3s ease
  
  &:hover
    transform: scale(1.02)

.author-avatar
  width: 180px
  height: 180px
  object-fit: cover
  border-radius: 50%

// 标签区域
.author-tag-left,
.author-tag-right
  display: flex
  flex-direction: column
  gap: 6px

.author-tag-left
  align-items: flex-end
  
  .author-tag
    &:first-child,
    &:last-child
      margin-right: -16px

.author-tag-right
  align-items: flex-start

.author-tag
  padding: 4px 12px
  background: var(--card)
  border: 1px solid var(--block-border)
  border-radius: 40px
  font-size: 14px
  font-weight: 700
  color: var(--text-p1)
  box-shadow: var(--shadow-card)
  animation: tag-float 6s ease-in-out infinite
  will-change: transform, opacity
  white-space: nowrap

// 标签浮动动画
@keyframes tag-float
  0%, 100%
    transform: translateY(-4px)
    opacity: 1
  50%
    transform: translateY(4px)
    opacity: 0.8

// 页面内容布局
.author-page-content
  display: flex
  flex-direction: column
  gap: 0.5rem
  max-width: 100%
  align-items: center

.author-content
  display: flex
  flex-wrap: wrap
  justify-content: center
  width: 100%
  gap: 0.5rem
  max-width: 100%
  box-sizing: border-box

.author-content-item
  border-radius: $border-card
  background: var(--card)
  border: 1px solid var(--block-border)
  box-shadow: var(--shadow-card)
  position: relative
  padding: 1rem
  overflow: hidden
  flex: 1
  min-width: 280px
  box-sizing: border-box
  max-width: 100%

  @media screen and (min-width: 1300px)
    animation: slide-in 0.6s 0s backwards

.author-content-item-tips
  opacity: 0.8
  font-size: 12px
  margin-bottom: 0.5rem
  color: var(--text-p2)

.author-content-item-title
  font-size: 1.875rem
  line-height: 2.25rem
  color: var(--text-p1)
  font-weight: 600

.author-content-item-content
  margin-bottom: 1rem
  margin-top: 0.5rem
  color: var(--text-p2)
  line-height: 1.6

// myInfoAndSayHello 组件
.myInfoAndSayHello
  display: flex
  flex-direction: column
  justify-content: center
  color: white
  background: linear-gradient(120deg, #5b27ff 0%, #00d4ff 100%)
  background-size: 200%
  min-height: 175px
  width: 100%
  box-sizing: border-box
  
  .title1
    opacity: 0.8
    line-height: 1.3
    font-size: 1rem
  
  .title2
    font-size: 36px
    font-weight: 700
    line-height: 1.1
    margin: 0.5rem 0
  
  .inline-word
    word-break: keep-all
    white-space: nowrap

// aboutsiteTips 组件
.aboutsiteTips
  display: flex
  justify-content: center
  align-items: flex-start
  flex-direction: column
  flex: 3
  max-width: 100%
  
  h2
    margin-right: auto
    font-size: 36px
    font-family: Helvetica, system-ui, sans-serif
    line-height: 1.06
    letter-spacing: -0.02em
    color: var(--text-p1)
    margin-top: 0
    font-weight: 600
    max-width: 100%
    word-break: break-word
  
  .mask
    height: 44px
    position: relative
    overflow: hidden
    margin-top: 4px
    
    span
      display: block
      box-sizing: border-box
      position: absolute
      top: 44px
      left: 0
      padding-bottom: 0
      background-size: 100% 100%
      -webkit-background-clip: text
      background-clip: text
      -webkit-text-fill-color: transparent
      background-repeat: no-repeat
      font-size: 36px
      font-weight: 600
      line-height: 1.15
      transform: translateY(0)
      transition: transform 0.5s ease-in-out
      white-space: nowrap
      
      &:nth-child(1)
        background-image: linear-gradient(45deg, #0ecffe 50%, #07a6f1)
      
      &:nth-child(2)
        background-image: linear-gradient(45deg, #18e198 50%, #0ec15d)
      
      &:nth-child(3)
        background-image: linear-gradient(45deg, #8a7cfb 50%, #633e9c)
      
      &:nth-child(4)
        background-image: linear-gradient(45deg, #fa7671 50%, #f45f7f)
    
    // 当前显示的文本（在中间）
    span[data-show]
      transform: translateY(-100%)
      transition: transform 0.5s ease-in-out
    
    // 已经滚出的文本（在上面）
    span[data-up]
      transform: translateY(-200%)
      transition: transform 0.5s ease-in-out
    
    // 等待进入的文本（在下面）
    span[data-wait]
      transform: translateY(0)
      opacity: 0

// 座右铭组件
.maxim
  flex: 1
  display: flex
  flex-direction: column
  justify-content: center
  min-width: 200px

// 技能组件
creativityMain
  width: 100%
  max-width: 100%

.author-content-item-list
  display: flex
  flex-wrap: wrap
  gap: 8px

.cardInfo
  display: flex
  align-items: center

.skill-badge
  display: flex
  align-items: center
  gap: 6px
  padding: 0.5rem 0.75rem
  background: var(--block)
  border: 1px solid var(--block-border)
  border-radius: $border-bar
  transition: all 0.3s ease
  
  &:hover
    transform: translateY(-2px)
    box-shadow: var(--shadow-card)
    border-color: var(--theme-a30)

.skill-icon
  width: 20px
  height: 20px
  object-fit: contain

.skill-name
  font-size: 14px
  font-weight: 500
  color: var(--text-p1)

// 历程组件
.single
  width: 100%
  max-width: 100%
  
  .lishi
    font-size: 1.5rem
    line-height: 2rem
    color: var(--text-p1)
    font-weight: 600
    margin-bottom: 1rem
  
  .singlePost
    margin-top: 1rem
    padding-top: 1rem
    border-top: 1px solid var(--block-border)
    word-break: break-word
    overflow-wrap: break-word
    
    .text-center
      text-align: center
      color: var(--text-p3)
      font-style: italic

// 滑入动画
@keyframes slide-in
  from
    opacity: 0
    transform: translateY(20px)
  to
    opacity: 1
    transform: translateY(0)

// 响应式适配
@media screen and (max-width: 768px)
  #about-page
    margin-left: auto
    margin-right: auto
    max-width: calc(100vw - 1rem)
  
  .author-main
    flex-direction: column
    gap: 16px
  
  .author-tag-left,
  .author-tag-right
    flex-direction: row
    flex-wrap: wrap
    justify-content: center
    align-items: center
    gap: 8px
    max-width: 100%
    
    .author-tag
      &:first-child,
      &:last-child
        margin-right: 0
  
  .author-content
    flex-direction: column
    margin-top: 0
    max-width: 100%
  
  .author-content-item
    width: 100% !important
    max-width: 100% !important
    padding: 1rem !important
    min-width: auto
    flex: none
    box-sizing: border-box
  
  .myInfoAndSayHello
    .title2
      font-size: 28px
  
  .aboutsiteTips
    h2
      font-size: 24px
      line-height: 1.2
      max-width: 100%
    
    .mask
      height: 32px
      
      span
        font-size: 24px
        top: 32px
        line-height: 1.2
  
  .author-tag
    animation-duration: 4s
  
  // 技能标签适配
  .author-content-item-list
    gap: 6px
  
  .skill-badge
    padding: 0.4rem 0.6rem
    
    .skill-icon
      width: 16px
      height: 16px
    
    .skill-name
      font-size: 12px

@media screen and (max-width: 480px)
  #about-page
    margin-left: auto
    margin-right: auto
    max-width: calc(100vw - 1rem)
  
  .author-box
    width: 140px
    height: 140px
  
  .author-img
    width: 140px
    height: 140px
  
  .author-avatar
    width: 140px
    height: 140px
  
  .myInfoAndSayHello
    .title2
      font-size: 24px
  
  .aboutsiteTips
    h2
      font-size: 20px
      line-height: 1.3
      max-width: 100%
    
    .mask
      height: 28px
      
      span
        font-size: 20px
        top: 28px
        line-height: 1.3
  
  // 技能标签更小屏幕适配
  .skill-badge
    padding: 0.3rem 0.5rem
    
    .skill-icon
      width: 14px
      height: 14px
    
    .skill-name
      font-size: 11px
