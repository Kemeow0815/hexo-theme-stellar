.widget-wrapper.moment
  .tag-plugin.timeline
    padding-left: 0
    &:before
      left: 6px
  
  .widget-body
    overflow: hidden
    max-height: 400px
    overflow-y: auto
    
    &::-webkit-scrollbar
      width: 4px
    
    &::-webkit-scrollbar-thumb
      background: var(--text-meta)
      border-radius: 4px
  
  // Moment 时间线节点样式
  .tag-plugin.timeline .timenode
    z-index: 1
    margin-top: 0.5rem
    position: relative
    
    &:before
      content: ''
      position: absolute
      left: 6px
      top: 12px
      width: 6px
      height: 6px
      border-radius: 50%
      background: var(--theme)
      z-index: 2
    
    &:after
      content: ''
      position: absolute
      left: 8px
      top: 20px
      bottom: -8px
      width: 2px
      background: var(--block-border)
      z-index: 1
    
    &:last-child:after
      display: none
    
    .header
      margin: 0 0 0.25rem 1.5rem
      display: flex
      justify-content: space-between
      align-items: center
      font-size: $fs-12
      color: var(--text-p3)
      
      .time
        font-weight: 500
      
      .views
        opacity: 0.8
    
    .body
      margin-left: 1.5rem
      border-radius: $border-card-s
      padding: 0.75rem 1rem
      background: var(--block)
      border: 1px solid var(--block-border)
      
      .content
        font-size: $fs-14
        line-height: 1.6
        color: var(--text-p1)
        word-break: break-word
        
        // 处理 emoji 图片
        .emoji
          display: inline-block
          width: 1.2em
          height: 1.2em
          background-size: contain
          background-repeat: no-repeat
          background-position: center
          vertical-align: middle
          margin: 0 2px
          
          b
            display: none
      
      // 图片网格
    .images
      display: grid
      grid-template-columns: repeat(3, 1fr)
      gap: 4px
      margin-top: 0.5rem
      
      .image-item
        aspect-ratio: 1
        border-radius: $border-image-s
        overflow: hidden
        cursor: pointer
        
        a
          display: block
          width: 100%
          height: 100%
          
          img
            width: 100%
            height: 100%
            object-fit: cover
            transition: transform 0.3s ease
            
          &:hover
            img
              transform: scale(1.05)
      
      // 空状态
      &.empty,
      &.error
        text-align: center
        color: var(--text-p3)
        padding: 1rem
        
        p
          margin: 0

// 左侧栏适配
.l_left .widget-wrapper.moment
  .tag-plugin.timeline
    padding-left: 0
    
    &:before
      content: none
  
  .timenode
    .body
      box-shadow: none
      background: var(--bg-a50)
