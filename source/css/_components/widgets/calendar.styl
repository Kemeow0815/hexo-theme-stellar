.widget-wrapper.calendar-schedule,
.widget-wrapper.calendar-main
  .widget-body
    padding: 0.5rem
    overflow: hidden

// Schedule 样式
#card-widget-schedule
  display: flex
  gap: 8px
  
  #schedule-area-left
    width: 30%
    display: flex
    flex-direction: column
    justify-content: center
    align-items: center
    text-align: center
    
    #schedule-title
      font-size: 12px
      color: var(--text-p3)
      margin-bottom: 4px
    
    #schedule-days
      font-size: 28px
      font-weight: 700
      color: var(--theme)
      line-height: 1
    
    #schedule-date
      font-size: 11px
      color: var(--text-p3)
      margin-top: 4px
  
  #schedule-area-right
    width: 70%
    display: flex
    flex-direction: column
    gap: 8px
    
    .schedule-r0, .schedule-r1, .schedule-r2
      display: flex
      align-items: center
      height: 1.8rem
      
      .schedule-d0
        width: 32px
        font-size: 11px
        color: var(--text-p3)
        text-align: center
      
      .schedule-d1
        flex: 1
        position: relative
        display: flex
        align-items: center
        height: 100%
        
        progress
          width: 100%
          height: 6px
          border-radius: 3px
          overflow: hidden
          background: var(--block)
          
          &::-webkit-progress-bar
            background: var(--block)
          
          &::-webkit-progress-value
            background: var(--theme)
            border-radius: 3px
        
        .aside-span1
          position: absolute
          left: 4px
          font-size: 10px
          color: var(--card)
          z-index: 1
          text-shadow: 0 1px 2px rgba(0,0,0,0.3)
        
        .aside-span2
          position: absolute
          right: 0
          font-size: 10px
          color: var(--text-p2)
          
          a
            color: var(--text-p1)
            font-weight: 600

// Calendar 样式 - 覆盖 calendar.css 的绝对定位
#card-widget-calendar
  display: flex
  gap: 8px
  width: 100%
  position: relative
  
  #calendar-area-left
    width: 40%
    display: flex
    flex-direction: column
    align-items: center
    justify-content: flex-start
    text-align: center
    padding: 4px
    position: relative
    
    #calendar-week
      font-size: 12px
      color: var(--text-p3)
      line-height: 1.4
      margin-bottom: 4px
      position: relative
      height: auto
    
    #calendar-date
      font-size: 32px
      font-weight: 700
      color: var(--theme)
      line-height: 1
      margin: 4px 0
      position: relative
      height: auto
      top: auto
      display: block
    
    #calendar-solar
      font-size: 10px
      color: var(--text-p2)
      line-height: 1.4
      margin-top: 4px
      position: relative
      height: auto
      bottom: auto
      display: block
    
    #calendar-lunar
      font-size: 10px
      color: var(--text-p3)
      line-height: 1.4
      margin-top: 2px
      position: relative
      height: auto
      bottom: auto
      display: block
  
  #calendar-area-right
    width: 60%
    display: flex
    align-items: flex-start
    
    #calendar-main
      width: 100%
      
      .calendar-rh
        display: flex
        margin-bottom: 2px
        
        .calendar-d0, .calendar-d1, .calendar-d2, .calendar-d3, .calendar-d4, .calendar-d5, .calendar-d6
          flex: 1
          text-align: center
          font-size: 9px
          color: var(--text-p3)
          padding: 1px 0
      
      .calendar-r0, .calendar-r1, .calendar-r2, .calendar-r3, .calendar-r4, .calendar-r5
        display: flex
        height: 18px
        
        .calendar-d0, .calendar-d1, .calendar-d2, .calendar-d3, .calendar-d4, .calendar-d5, .calendar-d6
          flex: 1
          display: flex
          justify-content: center
          align-items: center
          
          a
            width: 16px
            height: 16px
            display: flex
            justify-content: center
            align-items: center
            font-size: 10px
            color: var(--text-p1)
            border-radius: 50%
            text-decoration: none
            
            &.now
              background: var(--theme)
              color: var(--card)
              font-weight: 600

// 左侧栏适配
.l_left .widget-wrapper.calendar-schedule,
.l_left .widget-wrapper.calendar-main
  .widget-body
    background: var(--bg-a50)
    border-radius: $border-card-s
