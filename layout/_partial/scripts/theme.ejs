<script type="text/javascript">
  const applyTheme = (theme) => {
    if (theme === 'auto') {
      document.documentElement.removeAttribute('data-theme')
    } else {
      document.documentElement.setAttribute('data-theme', theme)
    }

    // applyThemeToGiscus(theme)
  }

  // FIXME: 这会导致无法使用 preferred_color_scheme 以外的主题
  const applyThemeToGiscus = (theme) => {
    // theme = theme === 'auto' ? 'preferred_color_scheme' : theme
    const cmt = document.getElementById('giscus')
    if (cmt) {
      // This works before giscus load.
      cmt.setAttribute('data-theme', theme)
    }

    const iframe = document.querySelector('#comments > section.giscus > iframe')
    if (iframe) {
      // This works after giscus loaded.
      const src = iframe.src
      const newSrc = src.replace(/theme=[\w]+/, `theme=${theme}`)
      iframe.src = newSrc
    }
  }

  const switchTheme = () => {
    // light -> dark -> auto -> light -> ...
    const currentTheme = document.documentElement.getAttribute('data-theme')
    let newTheme;
    switch (currentTheme) {
      case 'light':
        newTheme = 'dark'
        break
      case 'dark':
        newTheme = 'auto'
        break
      default:
        newTheme = 'light'
    }
    applyTheme(newTheme)
    window.localStorage.setItem('Stellar.theme', newTheme)
    utils.dark.mode = newTheme === 'auto' ? (window.matchMedia("(prefers-color-scheme: dark)").matches ? "dark" : "light") : newTheme;
    utils.dark.method.toggle.start();

    const messages = {
      light: `<%- __('message.theme_switched.light') %>`,
      dark: `<%- __('message.theme_switched.dark') %>`,
      auto: `<%- __('message.theme_switched.auto') %>`,
    }
    hud?.toast?.(messages[newTheme])
  }

  // 切换到指定主题模式
  const switchToTheme = (theme, message) => {
    applyTheme(theme)
    window.localStorage.setItem('Stellar.theme', theme)
    utils.dark.mode = theme === 'auto' ? (window.matchMedia("(prefers-color-scheme: dark)").matches ? "dark" : "light") : theme;
    utils.dark.method.toggle.start();
    hud?.toast?.(message)
  }

  // 更新主题切换按钮图标
  const updateThemeToggleIcon = (theme) => {
    const toggleBtn = document.getElementById('ThemeToggle')
    if (!toggleBtn) return

    const icons = {
      light: 'https://upyun.thatcdn.cn/public/img/icon/Sun.png',
      dark: 'https://upyun.thatcdn.cn/public/img/icon/Moon.png',
      auto: 'https://upyun.thatcdn.cn/public/img/icon/AI.png'
    }
    toggleBtn.src = icons[theme] || icons.light
  }

  // 绑定单一主题切换按钮
  const bindThemeButtons = () => {
    const toggleBtn = document.getElementById('ThemeToggle')

    if (toggleBtn) {
      toggleBtn.closest('a')?.addEventListener('click', (e) => {
        e.preventDefault()
        switchTheme()
        // 切换后更新图标
        const currentTheme = document.documentElement.getAttribute('data-theme') || 'auto'
        updateThemeToggleIcon(currentTheme)
      })
    }
  }

  (() => {
    // Apply user's preferred theme, if any.
    const theme = window.localStorage.getItem('Stellar.theme')
    if (theme !== null) {
      applyTheme(theme)
    } else {
      utils.dark.mode = window.matchMedia("(prefers-color-scheme: dark)").matches ? "dark" : "light";
    }
    utils.dark.method.toggle.start();

    // 绑定主题切换按钮
    bindThemeButtons()

    // 初始化按钮图标
    const currentTheme = document.documentElement.getAttribute('data-theme') || 'auto'
    updateThemeToggleIcon(currentTheme)
  })()

  // PJAX 后重新绑定按钮
  document.addEventListener('pjax:complete', bindThemeButtons)
</script>
