<%
const content = theme.footer.content?.replace('{author.name}', (config.author || 'Anonymity'))?.replace('{theme.name}', stellar_info('name'))?.replace('{theme.version}', stellar_info('version'))?.replace('{theme.tree}', stellar_info('tree'))
function layoutDiv() {
  var el = ''
  el += `<footer class="page-footer${scrollreveal(' ')} footnote">`
  el += '<hr>'
  // sitemap
  const sitemap = theme.footer.sitemap
  if (sitemap?.length > 0) {
    var count = sitemap.length
    if ([6].includes(count)) {
      count = 3
    } else if ([7,8].includes(count)) {
      count = 4
    } else {
      count = Math.min(sitemap.length, 5)
    }
    el += `<div class="sitemap" style="column-count:${count};">`
    for (let group of sitemap) {
      let title = group.title
      let items = group.items
      if (items == undefined || items.length == 0) {
        continue
      }
      el += '<div class="sitemap-group">'
      el += '<span class="fs15">' + title + '</span>'
      items.forEach((item, i) => {
        el += '<a href="' + url_for(md_link(item)) + '">'
        el += __(md_text(item))
        el += '</a>'
      });
      el += '</div>'
    }
    el += '</div>'
  }
  // footer
  el += '<div class="text">'
  if (content) {
    el += markdown(content)
  }
  // 添加全站字数统计
  el += '<div style="margin-top: 8px; text-align: center;">'
  el += '<span class="totalcount">共发表 ' + site.posts.length + ' 篇Blog · </span>'
  el += '<span class="post-count">总计 ' + totalcount(site) + ' 字</span>'
  el += '</div>'
  el += '</div>'
  // runtime script
  el += '<script type="text/javascript">'
  el += '(function() {'
  el += 'var START_DATE = Date.UTC(2024, 9, 1, 12, 0, 0);'
  el += 'var UPDATE_INTERVAL = 1000;'
  el += 'var SECOND = 1000;'
  el += 'var MINUTE = SECOND * 60;'
  el += 'var HOUR = MINUTE * 60;'
  el += 'var DAY = HOUR * 24;'
  el += 'var YEAR = DAY * 365;'
  el += 'function formatNumber(num) { return num < 10 ? "0" + num : num.toString(); }'
  el += 'function showRuntime() {'
  el += 'try {'
  el += 'var now = new Date();'
  el += 'var currentTime = Date.UTC(now.getFullYear(), now.getMonth(), now.getDate(), now.getHours(), now.getMinutes(), now.getSeconds());'
  el += 'var diff = currentTime - START_DATE;'
  el += 'if (diff < 0) { return; }'
  el += 'var years = Math.floor(diff / YEAR);'
  el += 'var remainingAfterYears = diff % YEAR;'
  el += 'var days = Math.floor(remainingAfterYears / DAY);'
  el += 'var remainingAfterDays = remainingAfterYears % DAY;'
  el += 'var hours = Math.floor(remainingAfterDays / HOUR);'
  el += 'var remainingAfterHours = remainingAfterDays % HOUR;'
  el += 'var minutes = Math.floor(remainingAfterHours / MINUTE);'
  el += 'var seconds = Math.floor((remainingAfterHours % MINUTE) / SECOND);'
  el += 'var runtimeSpan = document.getElementById("runtime_span");'
  el += 'if (runtimeSpan) {'
  el += 'runtimeSpan.innerHTML = "🦉 本站已安全运行：" + years + " 年 " + days + " 天 " + formatNumber(hours) + " 小时 " + formatNumber(minutes) + " 分钟 " + formatNumber(seconds) + " 秒 🦉";'
  el += '}'
  el += '} catch (error) {'
  el += 'var runtimeSpan = document.getElementById("runtime_span");'
  el += 'if (runtimeSpan) { runtimeSpan.innerHTML = "🦉 运行时间计算失败 🦉"; }'
  el += '}'
  el += '}'
  el += 'if (document.readyState === "loading") { document.addEventListener("DOMContentLoaded", startTimer); } else { startTimer(); }'
  el += 'function startTimer() { showRuntime(); setInterval(showRuntime, UPDATE_INTERVAL); }'
  el += '})();'
  el += '</script>'
  el += '</footer>'
  return el
}
%>
<%- layoutDiv() %>
