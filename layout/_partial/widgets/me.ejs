<%
function layoutDiv() {
  var el = '';
  
  // 获取统计数据
  var postsCount = site.posts.length || 0;
  var tagsCount = site.tags.length || 0;
  var categoriesCount = site.categories.length || 0;
  
  // 头像配置
  var avatar = item.avatar || config.avatar || '/blog/images/avatar.png';
  var badge = item.badge || avatar;
  var name = item.name || config.author || '博主';
  var welcome = item.welcome || '👋 欢迎光临！';
  var github = item.github || 'https://github.com/Kemeow0815';
  var bio = item.bio || '一个热爱技术、热爱生活的博主！🎉';
  
  el += '<div class="me-widget">';
  
  // 欢迎语
  el += '<div class="me-header">';
  el += '<span class="me-welcome">' + welcome + '</span>';
  el += '</div>';
  
  // 头像（带悬停弹出卡片）
  el += '<div class="me-avatar-wrapper">';
  el += '<div class="me-avatar">';
  el += '<img src="' + avatar + '" alt="avatar" class="me-avatar-img">';
  el += '<div class="me-avatar-badge">';
  el += '<img src="' + badge + '" alt="badge">';
  el += '</div>';
  el += '</div>';
  
  // 悬停弹出的个人介绍卡片
  el += '<div class="me-hover-card">';
  el += '<div class="me-hover-header">';
  el += '<img src="' + avatar + '" alt="avatar" class="me-hover-avatar">';
  el += '<span class="me-hover-welcome">' + welcome + '</span>';
  el += '</div>';
  el += '<div class="me-hover-bio">' + bio + '</div>';
  el += '</div>';
  
  el += '</div>';
  
  // 用户名
  el += '<div class="me-name">' + name + '</div>';
  
  // 统计数据
  el += '<div class="me-stats">';
  el += '<div class="me-stat-item">';
  el += '<span class="me-stat-label">文章</span>';
  el += '<span class="me-stat-value">' + postsCount + '</span>';
  el += '</div>';
  el += '<div class="me-stat-item">';
  el += '<span class="me-stat-label">标签</span>';
  el += '<span class="me-stat-value">' + tagsCount + '</span>';
  el += '</div>';
  el += '<div class="me-stat-item">';
  el += '<span class="me-stat-label">分类</span>';
  el += '<span class="me-stat-value">' + categoriesCount + '</span>';
  el += '</div>';
  el += '</div>';
  
  // Follow Me 按钮
  el += '<a href="' + github + '" target="_blank" rel="noopener" class="me-follow-btn">';
  el += '<svg viewBox="0 0 24 24" width="16" height="16"><path fill="currentColor" d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"/></svg>';
  el += '<span>Follow Me</span>';
  el += '<span class="me-rocket">🚀</span>';
  el += '</a>';
  
  el += '</div>';
  
  return el;
}
%>
<%- layoutDiv() %>