<%
// 赞助页面模板
// 基于 Stellar 主题布局

// 读取 sponsor.yml 配置
var sponsorConfig = {};
try {
  sponsorConfig = site.data.sponsor || {};
} catch(e) {
  console.log('sponsor.yml not found');
}

var pageTitle = sponsorConfig.title || page.title || '赞赏支持';
var pageSubtitle = sponsorConfig.subtitle || page.subtitle || '感谢每一位支持我的朋友';
var methods = sponsorConfig.methods || {};
var description = sponsorConfig.description || '';
var api = sponsorConfig.api || '';
%>

<div class="sponsor-page">
  <!-- 页面头部 -->
  <div class="sponsor-header">
    <h1 class="sponsor-title"><%= pageTitle %></h1>
    <p class="sponsor-subtitle"><%= pageSubtitle %></p>
  </div>

  <!-- 赞赏方式 -->
  <div class="sponsor-methods">
    <% if (methods.alipay && methods.alipay.qr) { %>
    <div class="sponsor-method-item">
      <div class="sponsor-qr">
        <img src="<%= methods.alipay.qr %>" alt="<%= methods.alipay.name || '支付宝' %>收款码" class="sponsor-qr-img">
      </div>
      <span class="sponsor-method-name"><%= methods.alipay.name || '支付宝' %>收款码</span>
    </div>
    <% } %>
    
    <% if (methods.wechat && methods.wechat.qr) { %>
    <div class="sponsor-method-item">
      <div class="sponsor-qr">
        <img src="<%= methods.wechat.qr %>" alt="<%= methods.wechat.name || '微信支付' %>收款码" class="sponsor-qr-img">
      </div>
      <span class="sponsor-method-name"><%= methods.wechat.name || '微信支付' %>收款码</span>
    </div>
    <% } %>
  </div>

  <!-- 感谢图片 -->
  <div class="sponsor-thanks">
    <img src="https://jsd.268682.xyz/gh/Kemeow0815/img@main/img/sponsor.webp" alt="感谢支持" class="sponsor-thanks-img">
  </div>

  <!-- 赞赏说明 -->
  <% if (description) { %>
  <div class="sponsor-description">
    <%- markdown(description) %>
  </div>
  <% } %>

  <!-- 赞赏列表 -->
  <div class="sponsor-list-section">
    <h2 class="sponsor-list-title">赞赏名单</h2>
    <div class="sponsor-list" id="sponsor-list" data-api="<%= api %>">
      <div class="sponsor-loading">
        <div class="loading-spinner"></div>
        <span>加载中...</span>
      </div>
    </div>
  </div>
</div>
